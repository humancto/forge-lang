@test
define test_zero_and_negative_numbers() {
    assert_eq(0 + 0,     0)
    assert_eq(-1 + 1,    0)
    assert_eq(-5 * -3,   15)
    assert_eq(-10 / 2,  -5)
    assert_eq(math.abs(-0), 0)
}

@test
define test_float_arithmetic_bounds() {
    assert(0.1 + 0.2 > 0.29)
    assert(0.1 + 0.2 < 0.31)
    assert(1.0 / 3.0 * 3.0 > 0.99)
}

@test
define test_nested_function_calls() {
    fn add(a, b) { return a + b }
    fn mul(a, b) { return a * b }
    assert_eq(add(mul(2, 3), mul(4, 5)), 26)
}

// ===========================================================================
// SECTION: Natural syntax completeness
// ===========================================================================

@test
define test_natural_syntax_full() {
    set x to 42
    assert_eq(x, 42)

    set mut counter to 0
    change counter to counter + 1
    change counter to counter + 1
    assert_eq(counter, 2)

    define square(n) { return n * n }
    assert_eq(square(7), 49)
}

@test
define test_otherwise_and_nah_both_work() {
    fn f(n) {
        if n > 0 { return "pos" } otherwise { return "neg" }
    }
    fn g(n) {
        if n > 0 { return "pos" } nah { return "neg" }
    }
    assert_eq(f(1),  "pos")
    assert_eq(f(-1), "neg")
    assert_eq(g(1),  "pos")
    assert_eq(g(-1), "neg")
}

