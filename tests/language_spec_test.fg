@test
define test_crypto_hashing() {
    // crypto module: sha256, md5, base64_encode, hmac_sha256, sha512
    let hash = crypto.sha256("hello")
    assert_eq(len(hash), 64)
    assert(starts_with(hash, "2cf24dba"))
}

@test
define test_crypto_md5() {
    let md5 = crypto.md5("hello")
    assert_eq(len(md5), 32)
    assert(starts_with(md5, "5d41402a"))
}

@test
define test_crypto_base64() {
    let encoded = crypto.base64_encode("hello")
    let decoded = crypto.base64_decode(encoded)
    assert_eq(decoded, "hello")
    assert(len(encoded) > 0)
}

@test
define test_crypto_hmac() {
    let sig = crypto.hmac_sha256("key", "message")
    assert_eq(len(sig), 64)
    // Same inputs always produce same HMAC
    let sig2 = crypto.hmac_sha256("key", "message")
    assert_eq(sig, sig2)
}

@test
define test_crypto_sha512() {
    let h = crypto.sha512("hello")
    assert_eq(len(h), 128)  // 512 bits = 128 hex chars
}

