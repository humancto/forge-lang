@test
define test_math_constants() {
    assert(math.pi > 3.14)
    assert(math.pi < 3.15)
    assert(math.e  > 2.71)
    assert(math.e  < 2.72)
}

@test
define test_math_basic_functions() {
    assert_eq(math.abs(-5),    5)
    assert_eq(math.abs(5),     5)
    assert_eq(math.floor(3.9), 3)
    assert_eq(math.ceil(3.1),  4)
    assert_eq(math.round(3.5), 4)
    assert_eq(math.round(3.4), 3)
    assert_eq(math.max(3, 7),  7)
    assert_eq(math.min(3, 7),  3)
}

@test
define test_math_pow_and_sqrt() {
    assert_eq(math.pow(2, 10),   1024.0)
    assert_eq(math.sqrt(144),    12.0)
    assert_eq(math.sqrt(4),      2.0)
    assert_eq(math.pow(3, 3),    27.0)
}

@test
define test_math_trig() {
    assert(math.sin(0) == 0.0)
    assert(math.cos(0) == 1.0)
    assert(math.sin(math.pi) < 0.001)
}

@test
define test_math_log() {
    assert(math.log(math.e) > 0.99)
    assert(math.log(math.e) < 1.01)
    assert(math.log(1) == 0.0)
}

