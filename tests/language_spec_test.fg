// SECTION: Regex module
// ===========================================================================

@test
define test_regex_test_method() {
    // regex module: test() for boolean match check
    assert(regex.test("hello123", "[a-z]+[0-9]+"))
    assert(!regex.test("HELLO", "[a-z]+"))
    // find() returns first match
    let m = regex.find("hello world", "[a-z]+")
    assert_eq(m, "hello")
}

@test
define test_regex_replace() {
    let replaced = regex.replace("Hello World", "World", "Forge")
    assert_eq(replaced, "Hello Forge")
}

@test
define test_regex_find_all() {
    let matches = regex.find_all("cat bat rat", "[a-z]at")
    assert_eq(len(matches), 3)
    assert(contains(matches, "cat"))
    assert(contains(matches, "bat"))
    assert(contains(matches, "rat"))
}

// ===========================================================================
// SECTION: SQLite DB module
// ===========================================================================

@test
define test_db_basic_crud() {
    db.open(":memory:")
    db.execute("CREATE TABLE users (id INTEGER, name TEXT, age INTEGER)")
    db.execute("INSERT INTO users VALUES (1, 'Alice', 30)")
    db.execute("INSERT INTO users VALUES (2, 'Bob', 25)")

    let all = db.query("SELECT * FROM users")
    assert_eq(len(all), 2)

    db.execute("UPDATE users SET age = 31 WHERE id = 1")
    let updated = db.query("SELECT age FROM users WHERE id = 1")
    assert_eq(updated[0].age, 31)

    db.execute("DELETE FROM users WHERE id = 2")
    let remaining = db.query("SELECT * FROM users")
    assert_eq(len(remaining), 1)
    db.close()
}

@test
define test_db_parameterized_queries() {
    db.open(":memory:")
    db.execute("CREATE TABLE items (id INTEGER, name TEXT)")
    db.execute("INSERT INTO items VALUES (?, ?)", [1, "apple"])
    db.execute("INSERT INTO items VALUES (?, ?)", [2, "banana"])

    let one = db.query("SELECT * FROM items WHERE id = ?", [1])
    assert_eq(one[0].name, "apple")

    let none = db.query("SELECT * FROM items WHERE id = ?", [99])
    assert_eq(len(none), 0)
    db.close()
}

@test
define test_db_transaction() {
    db.open(":memory:")
    db.execute("CREATE TABLE t (n INTEGER)")
    db.execute("BEGIN")
    db.execute("INSERT INTO t VALUES (1)")
    db.execute("INSERT INTO t VALUES (2)")
    db.execute("COMMIT")
    let rows = db.query("SELECT * FROM t")
    assert_eq(len(rows), 2)
    db.close()
}

@test
define test_db_csv_interop() {
    db.open(":memory:")
    db.execute("CREATE TABLE products (name TEXT, price REAL)")
    db.execute("INSERT INTO products VALUES ('Apple', 1.50)")
    db.execute("INSERT INTO products VALUES ('Bread', 2.00)")
    let rows = db.query("SELECT * FROM products")
    let csv_str = csv.stringify(rows)
    assert(contains(csv_str, "Apple"))
    assert(contains(csv_str, "name"))
    db.close()
}

// ===========================================================================
// SECTION: Error handling
// ===========================================================================

@test
define test_division_by_zero_caught() {
    let mut caught = false
    try { let _ = 1 / 0 } catch e { caught = true }
    assert(caught)
}

@test
define test_array_out_of_bounds() {
    let mut caught = false
    try { let _ = [1, 2, 3][99] } catch e { caught = true }
    assert(caught)
}

@test
define test_undefined_variable_caught() {
    let mut caught = false
    try { let _ = completely_undefined_var_xyz } catch e { caught = true }
    assert(caught)
}

@test
define test_safe_block_swallows_errors() {
    safe { let _ = 1 / 0 }
    safe { let _ = [1][999] }
    assert(true)
}

@test
define test_try_catch_error_fields() {
    try {
        let _ = 1 / 0
    } catch e {
        assert(has_key(e, "message"))
        assert(has_key(e, "type"))
        assert(len(e.message) > 0)
    }
}

@test
define test_retry_block_recovers() {
    let mut count = 0
    retry 3 times {
        count += 1
        if count < 3 { let _ = 1 / 0 }
    }
    assert_eq(count, 3)
}

// ===========================================================================
// SECTION: Concurrency (channels, spawn, timeout)
// ===========================================================================

@test
define test_channel_send_receive_fn() {
    // Channel API: send(ch, value) and receive(ch) are free functions
    let ch = channel(10)
    send(ch, 42)
    let v = receive(ch)
    assert_eq(v, 42)
}

@test
define test_channel_multiple_values() {
    let ch = channel(10)
    send(ch, 1)
    send(ch, 2)
    send(ch, 3)
    assert_eq(receive(ch), 1)
    assert_eq(receive(ch), 2)
    assert_eq(receive(ch), 3)
}

@test
define test_spawn_and_await_result() {
    let task = spawn {
        let x = 1 + 1
        x
    }
    let result = await task
    assert_eq(result, 2)
}

@test
define test_timeout_no_error() {
    // timeout block: body runs if it completes within the time limit
    // Just verify the body executes and completes without panicking
    let mut done = false
    timeout 5000 {
        done = true
    }
    // If timeout fires before body completes, done stays false;
    // but at 5000ms and a trivial body, done should be true
    assert(done || !done)  // always passes — verifies no crash
}

