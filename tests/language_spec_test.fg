@test
define test_object_keys_values_len() {
    let obj = { a: 1, b: 2, c: 3 }
    let k = keys(obj)
    let v = values(obj)
    assert_eq(len(k),   3)
    assert_eq(len(v),   3)
    assert(contains(k, "a"))
    assert(contains(v, 2))
    assert_eq(len(obj), 3)
}

@test
define test_object_has_key() {
    let obj = { name: "Alice", age: 30 }
    assert(has_key(obj,  "name"))
    assert(!has_key(obj, "email"))
}

@test
define test_object_get_with_default() {
    let obj = { name: "Alice" }
    assert_eq(get(obj, "name",  "unknown"), "Alice")
    assert_eq(get(obj, "email", "none"),    "none")
}

@test
define test_object_merge() {
    let a = { x: 1, y: 2 }
    let b = { y: 10, z: 3 }
    let m = merge(a, b)
    assert_eq(m.x, 1)
    assert_eq(m.y, 10)
    assert_eq(m.z, 3)
}

@test
define test_object_pick_and_omit() {
    let user = { name: "Bob", age: 25, role: "admin", active: true }
    let subset = pick(user, ["name", "role"])
    assert(has_key(subset,  "name"))
    assert(!has_key(subset, "age"))

    let without_age = omit(user, ["age"])
    assert(has_key(without_age,  "name"))
    assert(!has_key(without_age, "age"))
}

@test
define test_object_entries_roundtrip() {
    let orig = { x: 1, y: 2, z: 3 }
    let ents = entries(orig)
    let obj2 = from_entries(ents)
    assert_eq(obj2.x, 1)
    assert_eq(obj2.y, 2)
    assert_eq(obj2.z, 3)
}

@test
define test_object_from_entries() {
    let pairs = [["name", "Alice"], ["age", 30]]
    let obj = from_entries(pairs)
    assert_eq(obj.name, "Alice")
    assert_eq(obj.age,  30)
}

@test
define test_object_field_mutation() {
    let mut user = { name: "Alice", age: 30 }
    user.age = 31
    assert_eq(user.age, 31)
}

@test
define test_nested_object_deep_access() {
    let config = {
        server: { host: "localhost", port: 8080 },
        db: { url: "sqlite::memory:" }
    }
    assert_eq(config.server.port, 8080)
    assert_eq(config.db.url,      "sqlite::memory:")
    // Nested object field mutation support varies; test read-only deep access
    let port = config.server.port
    assert_eq(port, 8080)
}

@test
define test_nested_object_rebuilt() {
    // Deep mutation: rebuild the config with updated values
    let orig = { server: { port: 8080 } }
    let updated = merge(orig, { server: { port: 9090 } })
    assert_eq(updated.server.port, 9090)
}

@test
define test_object_as_function_arg() {
    fn greet(person) { return "Hello, {person.name}!" }
    assert_eq(greet({ name: "Alice" }), "Hello, Alice!")
}

@test
define test_empty_object_operations() {
    let obj = {}
    assert_eq(len(keys(obj)),   0)
    assert_eq(len(values(obj)), 0)
    assert(!has_key(obj, "any"))
}

