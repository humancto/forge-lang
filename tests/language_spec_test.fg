@test
define test_json_stringify_and_parse() {
    let obj = { name: "Alice", age: 30, active: true }
    let s = json.stringify(obj)
    assert(contains(s, "Alice"))
    assert(contains(s, "30"))
    let p = json.parse(s)
    assert_eq(p.name,   "Alice")
    assert_eq(p.age,    30)
}

@test
define test_json_parse_array() {
    let arr = json.parse("[1, 2, 3, 4, 5]")
    assert_eq(len(arr), 5)
    assert_eq(arr[0],   1)
    assert_eq(arr[4],   5)
}

@test
define test_json_nested_roundtrip() {
    let nested = { user: { name: "Bob", scores: [95, 87, 92] } }
    let s = json.stringify(nested)
    assert(contains(s, "Bob"))
    assert(contains(s, "95"))
    let p = json.parse(s)
    assert_eq(p.user.name, "Bob")
}

