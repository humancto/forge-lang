// language_spec_test.fg
// Comprehensive Forge language specification coverage test.
// Every section references the spec in docs/PROGRAMMING_FORGE.md.
// ALL strings/comments are ASCII-only to avoid lexer issues.

// ===========================================================================
// SECTION: Variables and Types
// ===========================================================================

@test
define test_typeof_primitives() {
    assert_eq(typeof(42),        "Int")
    assert_eq(typeof(-7),        "Int")
    assert_eq(typeof(0),         "Int")
    assert_eq(typeof(3.14),      "Float")
    assert_eq(typeof(-0.5),      "Float")
    assert_eq(typeof("hello"),   "String")
    assert_eq(typeof(""),        "String")
    assert_eq(typeof(true),      "Bool")
    assert_eq(typeof(false),     "Bool")
    assert_eq(typeof([1, 2, 3]), "Array")
    assert_eq(typeof([]),        "Array")
    assert_eq(typeof({ a: 1 }), "Object")
    assert_eq(typeof(null),      "Null")
}

@test
define test_type_alias_same_as_typeof() {
    assert_eq(type(42),      "Int")
    assert_eq(type("hello"), "String")
    assert_eq(type(true),    "Bool")
    assert_eq(type([]),      "Array")
    assert_eq(type(null),    "Null")
}

@test
define test_immutable_variable_cannot_reassign() {
    let mut caught = false
    try {
        let x = 10
        x = 20
    } catch e {
        caught = true
    }
    assert(caught)
}

@test
define test_mutable_classic_syntax() {
    let mut counter = 0
    counter = counter + 1
    counter = counter + 1
    assert_eq(counter, 2)
}

@test
define test_mutable_natural_syntax() {
    set mut score to 0
    change score to score + 10
    change score to score + 10
    assert_eq(score, 20)
}

@test
define test_compound_add_assign() {
    let mut x = 10
    x += 5
    assert_eq(x, 15)
}

@test
define test_compound_sub_assign() {
    let mut x = 10
    x -= 3
    assert_eq(x, 7)
}

@test
define test_compound_mul_assign() {
    let mut x = 6
    x *= 7
    assert_eq(x, 42)
}

@test
define test_compound_div_assign() {
    let mut x = 24
    x /= 4
    assert_eq(x, 6)
}

@test
define test_modulo_operator() {
    assert_eq(17 % 5, 2)
    assert_eq(10 % 3, 1)
    assert_eq(8 % 4,  0)
    assert_eq(7 % 7,  0)
    let mut x = 17
    x = x % 5
    assert_eq(x, 2)
}

@test
define test_percent_assign() {
    // BUG-001 FIXED: %= compound assignment now works
    let mut x = 17
    x %= 5
    assert_eq(x, 2)
    let mut y = 100
    y %= 7
    assert_eq(y, 2)  // 100 % 7 = 2
}

@test
define test_type_annotation_string_int() {
    let name: String = "Alice"
    let age: Int = 30
    assert_eq(name, "Alice")
    assert_eq(age, 30)
    assert_eq(typeof(name), "String")
    assert_eq(typeof(age),  "Int")
}

@test
define test_truthiness_falsy_values() {
    fn truthy(v) {
        if v { return true } else { return false }
    }
    assert(!truthy(false))
    assert(!truthy(null))
    assert(!truthy(0))
    assert(!truthy(0.0))
    assert(!truthy(""))
    assert(!truthy([]))
}

@test
define test_truthiness_truthy_values() {
    fn truthy(v) {
        if v { return true } else { return false }
    }
    assert(truthy(true))
    assert(truthy(1))
    assert(truthy(-1))
    assert(truthy(0.1))
    assert(truthy("a"))
    assert(truthy([0]))
    assert(truthy({ a: 1 }))
}

// ===========================================================================
// SECTION: Operators and Expressions
// ===========================================================================

@test
define test_integer_division_truncates() {
    assert_eq(7 / 2,    3)
    assert_eq(10 / 3,   3)
    assert_eq(-7 / 2,  -3)
    assert_eq(-10 / 3, -3)
}

@test
define test_float_division_promotes() {
    assert_eq(7.0 / 2,   3.5)
    assert_eq(7 / 2.0,   3.5)
    assert_eq(10.0 / 4,  2.5)
}

@test
define test_arithmetic_precedence() {
    assert_eq(2 + 3 * 4,   14)
    assert_eq((2 + 3) * 4, 20)
    assert_eq(10 - 2 * 3,   4)
}

@test
define test_string_comparison_all_operators() {
    // BUG-002 FIXED: string <, >, <=, >= now work in interpreter
    assert("apple" < "banana")
    assert("zebra" > "aardvark")
    assert("hello" == "hello")
    assert("hello" != "world")
    assert("a" < "b")
    assert("b" > "a")
    assert("abc" <= "abc")
    assert("abc" >= "abc")
    assert("abc" <= "abd")
    assert("abd" >= "abc")
    // Can use in sort_by for stable ordering
    let sorted = sort(["banana", "apple", "cherry"])
    assert_eq(sorted[0], "apple")
    assert_eq(sorted[2], "cherry")
}

@test
define test_logical_and_short_circuit() {
    let mut side = false
    fn mark() {
        side = true
        return true
    }
    let r = false && mark()
    assert(!r)
    assert(!side)
}

@test
define test_logical_or_short_circuit() {
    let mut side = false
    fn mark() {
        side = true
        return false
    }
    let r = true || mark()
    assert(r)
    assert(!side)
}

@test
define test_negation_and_double_negation() {
    assert(!false)
    assert(!!true)
    assert(!(1 == 2))
    assert(!!(1 == 1))
}

// ===========================================================================
// SECTION: Control Flow
// ===========================================================================

@test
define test_if_else_basic() {
    let mut r = ""
    if true  { r = "yes" } else { r = "no" }
    assert_eq(r, "yes")
    if false { r = "bad" } else { r = "good" }
    assert_eq(r, "good")
}

@test
define test_if_as_expression() {
    let x = 85
    fn get_grade(score) {
        if score >= 90 { return "A" } else if score >= 80 { return "B" } else { return "C" }
    }
    let grade = get_grade(x)
    assert_eq(grade, "B")
    let yn = if true { "yes" } else { "no" }
    assert_eq(yn, "yes")
}

@test
define test_otherwise_alias_else() {
    fn sign(n) {
        if n > 0 { return "pos" } otherwise { return "non-pos" }
    }
    assert_eq(sign(5),  "pos")
    assert_eq(sign(-1), "non-pos")
    assert_eq(sign(0),  "non-pos")
}

@test
define test_nah_alias_else() {
    fn done_msg(done) {
        if done { return "done" } nah { return "working" }
    }
    assert_eq(done_msg(true),  "done")
    assert_eq(done_msg(false), "working")
}

@test
define test_when_gt_comparisons() {
    fn classify_temp(t) {
        let mut label = ""
        when t {
            > 100 -> { label = "boiling" }
            > 80  -> { label = "hot" }
            > 60  -> { label = "warm" }
            > 40  -> { label = "cool" }
            else  -> { label = "cold" }
        }
        return label
    }
    assert_eq(classify_temp(110), "boiling")
    assert_eq(classify_temp(90),  "hot")
    assert_eq(classify_temp(70),  "warm")
    assert_eq(classify_temp(50),  "cool")
    assert_eq(classify_temp(30),  "cold")
}

@test
define test_when_lte_comparisons() {
    fn age_group(age) {
        let mut g = ""
        when age {
            <= 12 -> { g = "child" }
            <= 17 -> { g = "teen" }
            <= 64 -> { g = "adult" }
            else  -> { g = "senior" }
        }
        return g
    }
    assert_eq(age_group(8),  "child")
    assert_eq(age_group(12), "child")
    assert_eq(age_group(13), "teen")
    assert_eq(age_group(18), "adult")
    assert_eq(age_group(65), "senior")
}

@test
define test_when_equality_arm() {
    let mut result = ""
    let n = 3
    when n {
        == 1 -> { result = "one" }
        == 2 -> { result = "two" }
        == 3 -> { result = "three" }
        else -> { result = "other" }
    }
    assert_eq(result, "three")
}

@test
define test_for_in_array() {
    let mut sum = 0
    for x in [1, 2, 3, 4, 5] {
        sum += x
    }
    assert_eq(sum, 15)
}

@test
define test_for_each_natural_syntax() {
    let mut total = 0
    for each n in [10, 20, 30] {
        total += n
    }
    assert_eq(total, 60)
}

@test
define test_for_in_range_single_arg() {
    let items = range(5)
    assert_eq(len(items), 5)
    assert_eq(items[0], 0)
    assert_eq(items[4], 4)
}

@test
define test_for_in_range_two_args() {
    // range(start, end) produces [start, start+1, ..., end-1]
    let r = range(1, 6)
    assert_eq(len(r), 5)
    assert_eq(r[0],   1)
    assert_eq(r[4],   5)
    let mut total = 0
    for i in range(2, 7) {
        total += i
    }
    assert_eq(total, 20)  // 2+3+4+5+6 = 20
}

@test
define test_for_in_object_kv() {
    let obj = { a: 1, b: 2, c: 3 }
    let mut total = 0
    for key, val in obj {
        total += val
    }
    assert_eq(total, 6)
}

@test
define test_while_loop_accumulate() {
    let mut sum = 0
    let mut i = 0
    while i < 10 {
        i += 1
        sum += i
    }
    assert_eq(sum, 55)
}

@test
define test_while_with_break() {
    let mut i = 0
    while true {
        i += 1
        if i == 5 { break }
    }
    assert_eq(i, 5)
}

@test
define test_while_with_continue() {
    let mut sum = 0
    let mut i = 0
    while i < 10 {
        i += 1
        if i % 2 == 0 { continue }
        sum += i
    }
    assert_eq(sum, 25)
}

@test
define test_repeat_times_loop() {
    let mut count = 0
    repeat 5 times {
        count += 1
    }
    assert_eq(count, 5)
}

@test
define test_repeat_zero_times() {
    let mut count = 0
    repeat 0 times {
        count += 1
    }
    assert_eq(count, 0)
}

@test
define test_loop_break() {
    let mut i = 0
    loop {
        i += 1
        if i >= 5 { break }
    }
    assert_eq(i, 5)
}

@test
define test_loop_continue() {
    let mut odds = 0
    let mut i = 0
    loop {
        i += 1
        if i > 10 { break }
        if i % 2 == 0 { continue }
        odds += 1
    }
    assert_eq(odds, 5)
}

@test
define test_nested_break_innermost_only() {
    let mut outer = 0
    for _ in range(3) {
        outer += 1
        let mut inner = 0
        loop {
            inner += 1
            if inner == 2 { break }
        }
    }
    assert_eq(outer, 3)
}

@test
define test_for_with_break_early() {
    let mut last = -1
    for i in range(100) {
        last = i
        if i == 5 { break }
    }
    assert_eq(last, 5)
}

// ===========================================================================
// SECTION: Pattern Matching
// ===========================================================================

@test
define test_match_literal_int() {
    fn describe(x) {
        match x {
            1 => return "one"
            2 => return "two"
            3 => return "three"
            _ => return "other"
        }
    }
    assert_eq(describe(1),  "one")
    assert_eq(describe(2),  "two")
    assert_eq(describe(99), "other")
}

@test
define test_match_string_patterns() {
    fn greet(lang) {
        match lang {
            "en" => return "Hello"
            "es" => return "Hola"
            "fr" => return "Bonjour"
            _    => return "Hi"
        }
    }
    assert_eq(greet("en"), "Hello")
    assert_eq(greet("es"), "Hola")
    assert_eq(greet("fr"), "Bonjour")
    assert_eq(greet("de"), "Hi")
}

@test
define test_match_result_ok_err() {
    fn safe_div(a, b) {
        if b == 0 { return Err("division by zero") }
        return Ok(a / b)
    }
    match safe_div(10, 2) {
        Ok(v)  => assert_eq(v, 5)
        Err(e) => assert(false)
    }
    match safe_div(10, 0) {
        Ok(v)  => assert(false)
        Err(e) => assert(contains(e, "zero"))
    }
}

@test
define test_match_option_some_none() {
    fn safe_head(arr) {
        if len(arr) == 0 { return None }
        return Some(arr[0])
    }
    match safe_head([10, 20]) {
        Some(v) => assert_eq(v, 10)
        None    => assert(false)
    }
    match safe_head([]) {
        Some(v) => assert(false)
        None    => assert(true)
    }
}

@test
define test_match_adt_unit_variants() {
    type Color = Red | Green | Blue
    fn name(c) {
        match c {
            Red   => return "red"
            Green => return "green"
            Blue  => return "blue"
        }
    }
    assert_eq(name(Red),   "red")
    assert_eq(name(Green), "green")
    assert_eq(name(Blue),  "blue")
}

@test
define test_match_adt_constructor_fields() {
    type Shape = Circle(Float) | Rect(Float, Float)
    fn area(s) {
        match s {
            Circle(r)    => return 3.14 * r * r
            Rect(w, h)   => return w * h
        }
    }
    assert(area(Circle(1.0)) > 3.13)
    assert(area(Circle(1.0)) < 3.15)
    assert_eq(area(Rect(3.0, 4.0)), 12.0)
}

@test
define test_match_binding_captures_value() {
    let val = Ok(99)
    let mut captured = 0
    match val {
        Ok(n) => { captured = n }
        _     => {}
    }
    assert_eq(captured, 99)
}

@test
define test_match_three_adt_variants_with_fields() {
    type Shape = Circle(Float) | Rect(Float, Float) | Triangle(Float, Float, Float)
    fn area(s) {
        match s {
            Circle(r)          => return 3.14159 * r * r
            Rect(w, h)         => return w * h
            Triangle(a, b, c)  => {
                let sp = (a + b + c) / 2.0
                return math.sqrt(sp * (sp - a) * (sp - b) * (sp - c))
            }
        }
    }
    assert(area(Circle(1.0)) > 3.14)
    assert(area(Circle(1.0)) < 3.15)
    assert_eq(area(Rect(3.0, 4.0)), 12.0)
    assert(area(Triangle(3.0, 4.0, 5.0)) > 5.9)
    assert(area(Triangle(3.0, 4.0, 5.0)) < 6.1)
}

// ===========================================================================
// SECTION: Functions and Closures
// ===========================================================================

@test
define test_implicit_return_last_expr() {
    fn square(x) { x * x }
    fn add_one(x) { x + 1 }
    fn hello() { "hello" }
    assert_eq(square(5),   25)
    assert_eq(add_one(41), 42)
    assert_eq(hello(),     "hello")
}

@test
define test_explicit_return() {
    fn early(n) {
        if n < 0 { return -1 }
        return n * 2
    }
    assert_eq(early(-5),  -1)
    assert_eq(early(10),  20)
}

@test
define test_closure_captures_enclosing_scope() {
    fn make_adder(n) {
        return fn(x) { return x + n }
    }
    let add5  = make_adder(5)
    let add10 = make_adder(10)
    assert_eq(add5(3),  8)
    assert_eq(add10(3), 13)
    assert_eq(add5(10), 15)
}

@test
define test_closure_captures_scope_by_value() {
    // Forge closures capture the CURRENT value of outer variables (copy semantics).
    // The counter pattern works when the mutable variable is LOCAL to the closure.
    fn make_adder(base) {
        return fn(x) { return base + x }
    }
    let add10 = make_adder(10)
    let add20 = make_adder(20)
    assert_eq(add10(5), 15)
    assert_eq(add20(5), 25)
    assert_eq(add10(1), 11)
}

@test
define test_closure_independence() {
    // Closures with same factory have independent captured values
    fn make_adder(n) {
        return fn(x) { return x + n }
    }
    let add5  = make_adder(5)
    let add10 = make_adder(10)
    assert_eq(add5(1),  6)
    assert_eq(add10(1), 11)
    assert_eq(add5(1),  6)  // still 6, independent
}

@test
define test_higher_order_function_apply() {
    fn apply(f, v) { return f(v) }
    fn triple(x) { return x * 3 }
    fn negate(x) { return -x }
    assert_eq(apply(triple, 14),  42)
    assert_eq(apply(negate, 5),   -5)
}

@test
define test_anonymous_lambda() {
    let double = fn(x) { return x * 2 }
    let greet  = fn(name) { return "Hi {name}" }
    assert_eq(double(21),     42)
    assert_eq(greet("Forge"), "Hi Forge")
}

@test
define test_define_keyword_same_as_fn() {
    define double(x) { return x * 2 }
    fn triple(x) { return x * 3 }
    assert_eq(double(5), 10)
    assert_eq(triple(5), 15)
}

@test
define test_function_type_annotations() {
    fn multiply(a: Int, b: Int) -> Int { return a * b }
    fn greet(name: String) -> String { return "Hello, {name}!" }
    assert_eq(multiply(6, 7), 42)
    assert_eq(greet("Forge"), "Hello, Forge!")
}

@test
define test_recursion_factorial() {
    fn factorial(n) {
        if n <= 1 { return 1 }
        return n * factorial(n - 1)
    }
    assert_eq(factorial(0),  1)
    assert_eq(factorial(1),  1)
    assert_eq(factorial(5),  120)
    assert_eq(factorial(10), 3628800)
}

@test
define test_recursion_fibonacci() {
    fn fib(n) {
        if n <= 1 { return n }
        return fib(n - 1) + fib(n - 2)
    }
    assert_eq(fib(0),  0)
    assert_eq(fib(1),  1)
    assert_eq(fib(5),  5)
    assert_eq(fib(10), 55)
    assert_eq(fib(15), 610)
}

@test
define test_scope_shadowing_no_mutation() {
    let x = 10
    let result = {
        let x = 20
        x
    }
    assert_eq(result, 20)
    assert_eq(x, 10)
}

// ===========================================================================
// SECTION: Result and Option types
// ===========================================================================

@test
define test_ok_err_construction() {
    let ok  = Ok(42)
    let err = Err("bad")
    assert(is_ok(ok))
    assert(!is_ok(err))
    assert(is_err(err))
    assert(!is_err(ok))
}

@test
define test_some_none_construction() {
    let s = Some(42)
    let n = None
    assert(is_some(s))
    assert(!is_some(n))
    assert(is_none(n))
    assert(!is_none(s))
}

@test
define test_unwrap_ok_and_some() {
    assert_eq(unwrap(Ok(42)),    42)
    assert_eq(unwrap(Some(99)), 99)
    assert_eq(unwrap(Ok("hi")), "hi")
}

@test
define test_unwrap_or_result() {
    assert_eq(unwrap_or(Ok(100),    0), 100)
    assert_eq(unwrap_or(Err("x"),   0),   0)
}

@test
define test_unwrap_or_option() {
    assert_eq(unwrap_or(Some("hello"), "default"), "hello")
    assert_eq(unwrap_or(None,          "default"), "default")
}

@test
define test_try_operator_propagates_err() {
    fn parse_age(s) {
        let n = int(s)
        if n < 0 { return Err("negative") }
        return Ok(n)
    }
    fn process(s) {
        let age = parse_age(s)?
        return Ok("age is {age}")
    }
    assert(is_ok(process("25")))
    assert_eq(unwrap(process("25")), "age is 25")
    assert(is_err(process("-1")))
}

@test
define test_try_operator_chain() {
    fn step1(x) {
        if x < 0 { return Err("negative") }
        return Ok(x * 2)
    }
    fn step2(x) {
        if x > 100 { return Err("too big") }
        return Ok(x + 1)
    }
    fn pipeline(x) {
        let a = step1(x)?
        let b = step2(a)?
        return Ok(b)
    }
    assert_eq(unwrap(pipeline(5)), 11)
    assert(is_err(pipeline(-1)))
    assert(is_err(pipeline(60)))
}

@test
define test_must_on_ok() {
    let x = must Ok(42)
    assert_eq(x, 42)
    let s = must Ok("hello")
    assert_eq(s, "hello")
}

@test
define test_result_inside_option() {
    let wrapped = Some(Ok(42))
    assert(is_some(wrapped))
    let inner = unwrap(wrapped)
    assert(is_ok(inner))
    assert_eq(unwrap(inner), 42)
}

@test
define test_option_inside_result() {
    let val = Ok(Some(99))
    assert(is_ok(val))
    let opt = unwrap(val)
    assert(is_some(opt))
    assert_eq(unwrap(opt), 99)
}

// ===========================================================================
// SECTION: String built-ins
// ===========================================================================

@test
define test_string_length() {
    assert_eq(len("hello"), 5)
    assert_eq(len(""),      0)
    assert_eq(len("a"),     1)
}

@test
define test_string_concat() {
    assert_eq("hello" + " " + "world", "hello world")
    assert_eq("" + "x", "x")
}

@test
define test_string_interpolation_expressions() {
    let x = 7
    assert_eq("{x * x}", "49")
    assert_eq("{math.abs(-5)}", "5")
    assert_eq("{10 > 5}", "true")
}

@test
define test_string_upper_lower_trim() {
    // String transform methods are called on string values
    assert_eq("hello".upper(), "HELLO")
    assert_eq("WORLD".lower(), "world")
    assert_eq("Forge".upper(), "FORGE")
    assert_eq("".upper(), "")
    assert_eq("".lower(), "")
}

@test
define test_string_trim_method() {
    assert_eq("  hello  ".trim(), "hello")
    assert_eq("clean".trim(),     "clean")
    assert_eq("".trim(),          "")
}

@test
define test_string_starts_with_ends_with() {
    assert(starts_with("hello", "hel"))
    assert(!starts_with("hello", "ell"))
    assert(ends_with("hello", "llo"))
    assert(!ends_with("hello", "hel"))
}

@test
define test_string_contains() {
    assert(contains("hello world", "world"))
    assert(!contains("hello world", "xyz"))
    assert(contains("", ""))
}

@test
define test_string_replace() {
    assert_eq(replace("hello world", "world", "forge"), "hello forge")
    assert_eq(replace("aaa", "a", "b"),                 "bbb")
}

@test
define test_string_split_and_join() {
    let parts = split("a,b,c", ",")
    assert_eq(len(parts), 3)
    assert_eq(parts[0],   "a")
    assert_eq(parts[2],   "c")
    assert_eq(join(parts, "-"), "a-b-c")
}

@test
define test_string_index_of() {
    assert_eq(index_of("hello world", "world"),  6)
    assert_eq(index_of("hello world", "hello"),  0)
    assert_eq(index_of("hello world", "xyz"),   -1)
}

@test
define test_string_slice() {
    let s = "hello world"
    assert_eq(slice(s, 0, 5),  "hello")
    assert_eq(slice(s, 6, 11), "world")
    assert_eq(slice(s, 0, 0),  "")
}

@test
define test_string_reverse() {
    assert_eq(reverse("hello"), "olleh")
    assert_eq(reverse(""),      "")
    assert_eq(reverse("a"),     "a")
}

@test
define test_string_count_occurrences() {
    assert_eq(count("banana", "a"),  3)
    assert_eq(count("banana", "an"), 2)
    assert_eq(count("banana", "z"),  0)
}

@test
define test_string_to_int_and_float() {
    assert_eq(int("42"),     42)
    assert_eq(int("0"),       0)
    assert_eq(int("-7"),     -7)
    assert(float("3.14") > 3.13)
    assert(float("3.14") < 3.15)
}

@test
define test_str_conversion() {
    assert_eq(str(42),    "42")
    assert_eq(str(true),  "true")
    assert_eq(str(false), "false")
    assert_eq(str(null),  "null")
}

@test
define test_int_from_float_truncates() {
    assert_eq(int(3.99), 3)
    assert_eq(int(3.01), 3)
}

@test
define test_triple_quoted_strings() {
    // Triple-quoted strings are RAW - {expr} inside is NOT evaluated
    let lang = "Forge"
    let s = """Hello from {lang}"""
    // s = "Hello from {lang}" literally, NOT "Hello from Forge"
    assert_eq(len(s), 17)          // "Hello from {lang}" = 17 chars
    assert(starts_with(s, "Hello"))
    // Regular double-quoted strings DO interpolate
    let regular = "Hello from {lang}"
    assert_eq(regular, "Hello from Forge")
    assert_eq(len(regular), 16)    // "Hello from Forge" = 16 chars
    // SQL in triple-quoted - no interpolation issues
    let sql = """SELECT * FROM users"""
    assert(contains(sql, "SELECT"))
}

